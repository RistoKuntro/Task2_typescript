{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",
        "target": "ES2020",
        "module": "ES2020",
        "lib": ["ES2020", "DOM"],
        "sourceMap": true,
        "strict": true,
        "skipLibCheck": true,
        "moduleResolution": "node",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "declaration": false,
        "noEmit": false,
        "removeComments": true,
        "preserveConstEnums": true,
        "alwaysStrict": true
    },
    "include": ["src/task2.ts"],
    "exclude": ["node_modules", "dist"]
}
